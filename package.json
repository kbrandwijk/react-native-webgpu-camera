{
  "name": "react-native-webgpu-camera-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/react-native-skia/packages/skia",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter 'react-native-webgpu-camera' build",
    "build:skia": "cd packages/react-native-skia/packages/skia && SK_GRAPHITE=1 bunx tsx ./scripts/build-skia.ts",
    "install:skia-graphite": "cd packages/react-native-skia/packages/skia && bunx tsx ./scripts/install-skia-graphite.ts",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "example:ios": "cd apps/example && eas build --platform ios --profile development",
    "example:android": "cd apps/example && eas build --platform android --profile development"
  }
}
